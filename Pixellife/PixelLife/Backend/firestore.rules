rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザーデータ
    match /users/{userId} {
      // 本人のみ読み書き可能
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // AI クレジット
      match /ai_credits/{month} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 生成アセット
      match /generated_assets/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // トークン（Google等）
      match /tokens/{provider} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 天気キャッシュ（Functions からのみ書き込み、全ユーザー読み取り可）
    match /weather_cache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false; // Functions のみ admin SDK で書き込み
    }
  }
}
